@model GaoChongPortfolio.Models.ResumeViewModel

@{
    ViewData["Title"] = "Resume Registry & Terminal";
}

<div class="space-y-12">
    <!-- Introduction Section -->
    <div class="max-w-3xl">
        <h1 class="text-3xl font-extrabold tracking-tight text-white mb-2">Resume &amp; Diagnostics Terminal</h1>
        <p class="text-slate-400">
            Query Gao Chong's credentials using the interactive developer command line interface, or review the structured timeline below.
        </p>
    </div>

    <!-- Dual Layout: Terminal Console & Quick Skills -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Interactive Terminal Simulator (Left/Top) -->
        <div class="lg:col-span-8">
            <div class="bg-[#0b0f19] border border-slate-800 rounded-xl overflow-hidden shadow-2xl relative">
                <!-- Terminal Header Bar -->
                <div class="bg-slate-900 px-4 py-3 flex items-center justify-between border-b border-slate-800 select-none">
                    <div class="flex items-center space-x-2">
                        <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
                        <span class="w-3 h-3 rounded-full bg-yellow-500 inline-block"></span>
                        <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
                        <span class="text-xs font-mono text-slate-400 ml-2">powershell.exe - GaoChong@@CorePort</span>
                    </div>
                    <span class="text-xs font-mono text-slate-500">WSL: Ubuntu-22.04</span>
                </div>

                <!-- Terminal Buffer Output -->
                <div id="terminal-body" class="p-6 font-mono text-xs sm:text-sm h-80 overflow-y-auto space-y-2 text-slate-300">
                    <div class="text-slate-500">Microsoft Windows [Version 10.0.22631.3880]</div>
                    <div class="text-slate-500">(c) Microsoft Corporation. All rights reserved.</div>
                    <div class="mt-2 text-indigo-400 font-semibold">[SYS] Establishing secure connection to candidate host...</div>
                    <div class="text-emerald-400">[SYS] Session connected successfully.</div>
                    <div class="text-slate-400 mt-2">Welcome! Type <span class="text-white font-semibold">help</span> to list query commands.</div>
                    <div id="terminal-history"></div>
                </div>

                <!-- Terminal Input Line -->
                <div class="bg-black/40 border-t border-slate-800 px-6 py-3 flex items-center">
                    <span class="font-mono text-xs sm:text-sm text-indigo-400 mr-2 select-none">guest@@gaochong:~$</span>
                    <input type="text" id="terminal-input" class="bg-transparent border-0 outline-none text-xs sm:text-sm font-mono text-white flex-grow focus:ring-0 p-0" placeholder="Type command here..." autofocus />
                </div>
            </div>
        </div>

        <!-- Technical Skill Matrix Card (Right/Top) -->
        <div class="lg:col-span-4 flex flex-col justify-between">
            <div class="glass-panel border border-slate-800 rounded-xl p-6 shadow-xl flex-grow flex flex-col">
                <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span>Skill Group Registry</span>
                </h2>

                <div class="space-y-6 flex-grow">
                    @foreach (var group in Model.SkillGroups)
                    {
                        <div>
                            <h3 class="text-xs font-mono text-indigo-400 tracking-wider uppercase mb-2">@group.CategoryName</h3>
                            <div class="flex flex-wrap gap-1.5">
                                @foreach (var skill in group.Skills)
                                {
                                    <span class="text-xs px-2.5 py-1 rounded bg-slate-800 border border-slate-700 text-slate-300 font-mono hover:border-indigo-500/50 hover:bg-slate-900 transition duration-150">
                                        @skill
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Chronological Resume Timeline -->
    <section class="max-w-4xl pt-6">
        <h2 class="text-2xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <span>Professional Chronicles</span>
            <span class="h-px bg-slate-800 flex-grow"></span>
        </h2>

        <!-- Timeline wrapper -->
        <div class="relative border-l border-slate-800 ml-4 md:ml-6 space-y-12">
            @foreach (var exp in Model.Experiences)
            {
                <div class="relative pl-6 md:pl-10">
                    <!-- Bullet dot -->
                    <span class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-slate-950 border-2 border-indigo-500 shadow-md shadow-indigo-500/50 flex items-center justify-center">
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
                    </span>

                    <!-- Time & Company Header -->
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-1 mb-2">
                        <div>
                            <h3 class="text-xl font-bold text-white">@exp.Role</h3>
                            <div class="text-sm font-semibold text-indigo-400 font-mono mt-0.5">@exp.Company</div>
                        </div>
                        <span class="inline-block px-3 py-1 rounded bg-slate-900 border border-slate-800 text-xs font-mono text-slate-400 self-start md:self-center">
                            @exp.Duration
                        </span>
                    </div>

                    <!-- Bullet achievements -->
                    <ul class="list-disc pl-5 text-slate-300 text-sm space-y-2 mt-4 leading-relaxed">
                        @foreach (var point in exp.BulletPoints)
                        {
                            <li>@point</li>
                        }
                    </ul>

                    <!-- Humorous Takeaway -->
                    <div class="mt-4 p-3.5 rounded-lg bg-indigo-950/20 border border-indigo-500/10 text-xs text-indigo-300 font-mono flex items-start space-x-2">
                        <span class="select-none text-indigo-400 font-bold">[TAKEAWAY]</span>
                        <span>@exp.HumorousTakeaway</span>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Certifications and Accreditations -->
    <section class="max-w-4xl border-t border-slate-800/80 pt-8">
        <h2 class="text-xl font-bold text-white mb-4">Credentials &amp; Security Audits</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            @foreach (var cert in Model.Certifications)
            {
                <div class="p-4 rounded-lg bg-slate-900/60 border border-slate-800 flex items-center space-x-3 hover:border-indigo-500/30 transition duration-150">
                    <span class="text-xl">🏆</span>
                    <div class="text-xs sm:text-sm font-mono text-slate-300">@cert</div>
                </div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const inputField = document.getElementById('terminal-input');
        const historyContainer = document.getElementById('terminal-history');
        const terminalBody = document.getElementById('terminal-body');

        inputField.addEventListener('keydown', function(event) {
            if (event.key === 'Enter') {
                const commandText = inputField.value;
                inputField.value = '';

                if (commandText.trim() === '') return;

                // Log command locally
                appendLog(`guest@@gaochong:~$ ${commandText}`, 'text-indigo-300 mt-2 font-bold');

                if (commandText.toLowerCase() === 'clear') {
                    historyContainer.innerHTML = '';
                    return;
                }

                if (commandText.toLowerCase() === 'matrix') {
                    appendLog('[SYS] Retro override protocol triggered.', 'text-green-400 font-bold');
                    toggleHackerMode();
                    return;
                }

                // Query Controller API endpoint
                fetch(`/Resume/TerminalCommand?cmd=${encodeURIComponent(commandText)}`)
                    .then(response => response.json())
                    .then(data => {
                        appendLog(data.output, 'text-slate-300 whitespace-pre-wrap');
                    })
                    .catch(err => {
                        appendLog('[ERROR] Connection failure to local C# API router.', 'text-red-500 font-bold');
                    });
            }
        });

        function appendLog(text, className) {
            const div = document.createElement('div');
            div.className = className;
            div.innerText = text;
            historyContainer.appendChild(div);
            terminalBody.scrollTop = terminalBody.scrollHeight;
        }
    </script>
}

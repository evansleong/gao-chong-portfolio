@{
    ViewData["Title"] = "Home Gateway";
}

<div class="space-y-16">
    <!-- Hero / Bold Introduction Section -->
    <section class="relative min-h-[50vh] flex flex-col justify-center items-start overflow-hidden py-12">
        <!-- Floating gradient background shapes -->
        <div class="absolute top-10 right-10 w-72 h-72 bg-indigo-600/10 rounded-full blur-3xl -z-10"></div>
        <div class="absolute bottom-10 left-10 w-96 h-96 bg-purple-600/15 rounded-full blur-3xl -z-10"></div>

        <div class="max-w-4xl space-y-6">
            <!-- Witty Greeting Tag -->
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-indigo-500/30 bg-indigo-950/40 text-xs font-mono text-indigo-300">
                <span class="w-2 h-2 rounded-full bg-indigo-400 animate-ping"></span>
                <span>Console.WriteLine("Hello, World!");</span>
            </div>

            <!-- Main Heading with Typewriter feel -->
            <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white leading-tight">
                Hi, I'm <span class="bg-gradient-to-r from-indigo-400 via-violet-400 to-emerald-400 bg-clip-text text-transparent">Gao Chong</span>.
            </h1>

            <p class="text-lg sm:text-2xl text-slate-300 font-light leading-relaxed max-w-3xl">
                I build scalable full-stack applications, untangle chaotic log files, and occasionally build custom PCs without bending the CPU pins.
            </p>

            <!-- Action buttons -->
            <div class="flex flex-wrap gap-4 pt-4">
                <a href="/Resume" class="px-6 py-3 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm transition shadow-lg shadow-indigo-600/20 hover:shadow-indigo-600/40 transform hover:-translate-y-0.5">
                    Execute Resume.Read()
                </a>
                <a href="/Gallery" class="px-6 py-3 rounded-lg border border-slate-700 bg-slate-900/50 hover:bg-slate-800 hover:border-slate-600 text-slate-200 text-sm font-semibold transition">
                    View Project Registry
                </a>
                <a href="/Contact" class="px-6 py-3 rounded-lg border border-indigo-500/30 text-indigo-400 hover:bg-indigo-950/20 text-sm font-semibold transition">
                    Send Ping Request
                </a>
            </div>
        </div>
    </section>

    <!-- Bio / Deep Dive Section -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text Bio -->
        <div class="lg:col-span-7 space-y-6">
            <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white flex items-center gap-2">
                <span>About The Developer</span>
                <span class="h-px bg-slate-800 flex-grow ml-4"></span>
            </h2>
            <div class="text-slate-300 space-y-4 text-base sm:text-lg leading-relaxed">
                <p>
                    I am a full-stack software engineer with a heavy leaning towards robust, production-grade backend architectures, cloud integrations, and clean code. I believe code should not only compile, but be structured in a way that doesn't trigger migraines for future developers.
                </p>
                <p>
                    Over my years of writing code, I have survived countless recursive error loops, hunted down memory leaks in vendor DLL assemblies, and wrangled distributed cloud pipelines. Whether it's managing database deadlocks or building reactive mobile frontends, my approach is methodical, automated, and tested.
                </p>
                <p class="text-slate-400 italic text-sm border-l-2 border-indigo-500 pl-4 bg-slate-900/30 py-2 rounded-r">
                    Humorous Note: I am certified in reading sitecore logs without falling asleep, and I've successfully deployed code to production on a Friday without causing server explosions.
                </p>
            </div>
        </div>

        <!-- Visual / Hardware Info Box -->
        <div class="lg:col-span-5">
            <div class="glass-panel border border-slate-800 rounded-2xl p-6 shadow-xl relative overflow-hidden">
                <div class="absolute -top-16 -right-16 w-32 h-32 bg-indigo-500/10 rounded-full blur-2xl"></div>
                
                <h3 class="text-sm font-mono text-indigo-400 mb-4 flex items-center justify-between">
                    <span>SYS_STATS.log</span>
                    <span class="text-slate-500 text-xs">ONLINE</span>
                </h3>
                
                <div class="space-y-4 text-sm font-mono">
                    <div class="flex justify-between border-b border-slate-800/80 pb-2">
                        <span class="text-slate-400">Coffee Intake:</span>
                        <span class="text-slate-200">1.8 Liters/Day</span>
                    </div>
                    <div class="flex justify-between border-b border-slate-800/80 pb-2">
                        <span class="text-slate-400">CPU Pins Bent:</span>
                        <span class="text-emerald-400">0 Pins (Optimal)</span>
                    </div>
                    <div class="flex justify-between border-b border-slate-800/80 pb-2">
                        <span class="text-slate-400">Preferred Editor:</span>
                        <span class="text-slate-200">VS Code / Rider</span>
                    </div>
                    <div class="flex justify-between border-b border-slate-800/80 pb-2">
                        <span class="text-slate-400">OS Host:</span>
                        <span class="text-slate-200">Windows/Linux WSL</span>
                    </div>
                    <div class="flex justify-between border-b border-slate-800/80 pb-2">
                        <span class="text-slate-400">Production Hotfixes:</span>
                        <span class="text-yellow-400">0 (Tested locally!)</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-400">Humor Level:</span>
                        <span class="text-slate-200">Strictly Catch-Block</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Recruiter Assessment Simulator (Interactive UI Component) -->
    <section class="glass-panel border border-slate-800 rounded-2xl p-6 md:p-8 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4 font-mono text-xs text-slate-600">Widget-ID: RecruiterAssess_v2</div>
        <div class="max-w-xl mb-6">
            <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Recruiter Compatibility assessment</h2>
            <p class="text-sm text-slate-400">
                Are you a recruiter or hiring manager? Save time by running this automatic client-side candidate evaluation simulator.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <!-- Criteria buttons -->
            <button onclick="assessCandidate('tech')" class="hacker-override px-4 py-3 rounded-lg border border-slate-700 bg-slate-900/50 hover:bg-slate-800 text-left font-mono transition text-xs sm:text-sm text-slate-300 flex items-center justify-between">
                <span>[1] Assess Tech Stack</span>
                <span class="text-indigo-400 font-bold">&rarr;</span>
            </button>
            <button onclick="assessCandidate('soft')" class="hacker-override px-4 py-3 rounded-lg border border-slate-700 bg-slate-900/50 hover:bg-slate-800 text-left font-mono transition text-xs sm:text-sm text-slate-300 flex items-center justify-between">
                <span>[2] Assess Soft Skills</span>
                <span class="text-indigo-400 font-bold">&rarr;</span>
            </button>
            <button onclick="assessCandidate('fit')" class="hacker-override px-4 py-3 rounded-lg border border-slate-700 bg-slate-900/50 hover:bg-slate-800 text-left font-mono transition text-xs sm:text-sm text-slate-300 flex items-center justify-between">
                <span>[3] Assess Team Fit</span>
                <span class="text-indigo-400 font-bold">&rarr;</span>
            </button>
        </div>

        <!-- Simulator logs -->
        <div class="bg-black/60 border border-slate-800 rounded-xl p-4 font-mono text-xs h-40 overflow-y-auto" id="simulator-terminal">
            <div class="text-slate-500">&gt; Waiting for selector stimulus... Please click an assessment metric above.</div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const assessments = {
            tech: [
                "[SYS] Running candidate stack check...",
                "[INFO] Scanning C# compiler libraries: 100% compliant.",
                "[INFO] Checking AWS serverless resources: Rekognition OCR running efficiently.",
                "[INFO] Evaluating Sitecore DLL support: ILSpy and log-mitigation routines successfully verified.",
                "[SUCCESS] Candidate skill level: Senior-ready. Zero compiler warnings detected."
            ],
            soft: [
                "[SYS] Initiating team communication audit...",
                "[INFO] Checking documentation consistency: XML summaries are structured.",
                "[INFO] Reviewing PR comment logs: Constructive, precise, and polite.",
                "[SUCCESS] Empathy check passed. 100% chance of refactoring bad code without shaming the original author."
            ],
            fit: [
                "[SYS] Running team culture alignment scan...",
                "[INFO] Office coffee drinking rate: Within threshold parameters.",
                "[INFO] Meeting feedback loop: Prefers brief, efficient standups.",
                "[SUCCESS] Perfect alignment. Ready to onboard and merge code directly to main."
            ]
        };

        function assessCandidate(type) {
            const term = document.getElementById('simulator-terminal');
            term.innerHTML = ""; // Clear
            
            const logs = assessments[type];
            let delay = 0;
            
            logs.forEach((line, idx) => {
                setTimeout(() => {
                    const div = document.createElement('div');
                    if (line.startsWith("[SUCCESS]")) {
                        div.className = "text-emerald-400 font-bold mt-1";
                    } else if (line.startsWith("[WARN]")) {
                        div.className = "text-yellow-400";
                    } else if (line.startsWith("[SYS]")) {
                        div.className = "text-indigo-400";
                    } else {
                        div.className = "text-slate-300";
                    }
                    div.innerText = line;
                    term.appendChild(div);
                    term.scrollTop = term.scrollHeight;
                }, delay);
                delay += 250;
            });
        }
    </script>
}

@model GaoChongPortfolio.Models.PortfolioData

@{
    ViewData["Title"] = "System Dashboard";
}

<div class="space-y-8">
    <!-- Dashboard Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-800 pb-4">
        <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-white">Administration Dashboard</h1>
            <p class="text-xs text-slate-400 font-mono mt-1">Authorized User: @User.Identity?.Name | Access Token: ACTIVE</p>
        </div>
        <form asp-controller="Admin" asp-action="Logout" method="post" class="inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="hacker-override px-4 py-2 bg-red-950/60 border border-red-500/30 text-red-400 text-xs font-mono rounded-lg hover:bg-red-900 hover:text-white transition">
                Logout Session
            </button>
        </form>
    </div>

    <!-- Feedback Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="p-4 rounded-lg bg-emerald-950/30 border border-emerald-500/30 text-emerald-300 text-sm font-mono flex items-center space-x-2">
            <span>[SUCCESS]</span>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 rounded-lg bg-red-950/30 border border-red-500/30 text-red-300 text-sm font-mono flex items-center space-x-2">
            <span>[ERROR]</span>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- Primary Layout: Left = Bio management | Right = Experience & Projects list -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Bio Editor (Left column) -->
        <div class="lg:col-span-5 space-y-6">
            <div class="glass-panel border border-slate-800 rounded-xl p-6 shadow-xl">
                <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span>1. Edit Bio &amp; Global Headers</span>
                </h2>
                
                <form asp-controller="Admin" asp-action="EditBio" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    
                    <div class="space-y-1">
                        <label asp-for="Bio.HeroTitle" class="block text-[10px] font-mono text-indigo-300 uppercase">Hero Tagline</label>
                        <input asp-for="Bio.HeroTitle" class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                    </div>

                    <div class="space-y-1">
                        <label asp-for="Bio.HeroSubtitle" class="block text-[10px] font-mono text-indigo-300 uppercase">Hero Subtitle</label>
                        <textarea asp-for="Bio.HeroSubtitle" rows="3" class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-800 text-white text-xs"></textarea>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="Bio.BioText1" class="block text-[10px] font-mono text-indigo-300 uppercase">Bio Paragraph 1</label>
                        <textarea asp-for="Bio.BioText1" rows="4" class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-800 text-white text-xs"></textarea>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="Bio.BioText2" class="block text-[10px] font-mono text-indigo-300 uppercase">Bio Paragraph 2</label>
                        <textarea asp-for="Bio.BioText2" rows="4" class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-800 text-white text-xs"></textarea>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="Bio.BioHumorousNote" class="block text-[10px] font-mono text-indigo-300 uppercase">Humorous Bio Footer Note</label>
                        <input asp-for="Bio.BioHumorousNote" class="w-full px-3 py-2 rounded bg-slate-900 border border-slate-800 text-white text-xs" />
                    </div>

                    <!-- Telemetry Stats -->
                    <div class="border-t border-slate-850 pt-4 mt-4 space-y-3">
                        <h3 class="text-xs font-mono text-indigo-400 uppercase tracking-wider">System Telemetry Log Parameters</h3>
                        
                        <div class="grid grid-cols-2 gap-3">
                            <div class="space-y-1">
                                <label asp-for="Bio.CoffeeIntake" class="block text-[9px] font-mono text-slate-400 uppercase">Coffee Intake</label>
                                <input asp-for="Bio.CoffeeIntake" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                            <div class="space-y-1">
                                <label asp-for="Bio.CpuPinsBent" class="block text-[9px] font-mono text-slate-400 uppercase">CPU Pins Bent</label>
                                <input asp-for="Bio.CpuPinsBent" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                            <div class="space-y-1">
                                <label asp-for="Bio.PreferredEditor" class="block text-[9px] font-mono text-slate-400 uppercase">Preferred Editor</label>
                                <input asp-for="Bio.PreferredEditor" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                            <div class="space-y-1">
                                <label asp-for="Bio.OsHost" class="block text-[9px] font-mono text-slate-400 uppercase">OS Host</label>
                                <input asp-for="Bio.OsHost" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                            <div class="space-y-1">
                                <label asp-for="Bio.ProductionHotfixes" class="block text-[9px] font-mono text-slate-400 uppercase">Hotfixes</label>
                                <input asp-for="Bio.ProductionHotfixes" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                            <div class="space-y-1">
                                <label asp-for="Bio.HumorLevel" class="block text-[9px] font-mono text-slate-400 uppercase">Humor Level</label>
                                <input asp-for="Bio.HumorLevel" class="w-full px-2 py-1 rounded bg-slate-900 border border-slate-800 text-white text-xs font-mono" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="hacker-override w-full px-4 py-2 rounded bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-xs uppercase tracking-wider mt-4 transition">
                        Update Bio Parameters
                    </button>
                </form>
            </div>
        </div>

        <!-- Experience & Projects Listing (Right column) -->
        <div class="lg:col-span-7 space-y-6">
            
            <!-- Experiences Section -->
            <div class="glass-panel border border-slate-800 rounded-xl p-6 shadow-xl space-y-4">
                <div class="flex justify-between items-center pb-2 border-b border-slate-800">
                    <h2 class="text-lg font-bold text-white">2. Work Experience Chronology</h2>
                    <a href="/Admin/AddExperience" class="hacker-override px-3 py-1 bg-indigo-950 border border-indigo-500/30 text-indigo-400 text-xs font-mono rounded hover:bg-indigo-900 transition">
                        + Add Experience
                    </a>
                </div>

                <div class="space-y-3">
                    @for (int i = 0; i < Model.Experiences.Count; i++)
                    {
                        var exp = Model.Experiences[i];
                        <div class="p-4 rounded-lg bg-slate-900/50 border border-slate-800 flex items-center justify-between gap-4">
                            <div>
                                <h3 class="text-sm font-bold text-white">@exp.Role</h3>
                                <div class="text-xs text-indigo-400 font-mono">@exp.Company (@exp.Duration)</div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <a href="/Admin/EditExperience/@i" class="px-2.5 py-1.5 rounded bg-slate-850 hover:bg-slate-800 text-xs text-slate-300 transition border border-slate-700">
                                    Edit
                                </a>
                                <form asp-controller="Admin" asp-action="DeleteExperience" asp-route-id="@i" method="post" onsubmit="return confirm('Wipe experience entry? This operation cannot be rolled back.')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="px-2.5 py-1.5 rounded bg-red-950/60 border border-red-500/20 text-xs text-red-400 hover:bg-red-900 hover:text-white transition">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Projects Section -->
            <div class="glass-panel border border-slate-800 rounded-xl p-6 shadow-xl space-y-4">
                <div class="flex justify-between items-center pb-2 border-b border-slate-800">
                    <h2 class="text-lg font-bold text-white">3. Engineering Projects Registry</h2>
                    <a href="/Admin/AddProject" class="hacker-override px-3 py-1 bg-indigo-950 border border-indigo-500/30 text-indigo-400 text-xs font-mono rounded hover:bg-indigo-900 transition">
                        + Add Project
                    </a>
                </div>

                <div class="space-y-3">
                    @foreach (var proj in Model.Projects)
                    {
                        <div class="p-4 rounded-lg bg-slate-900/50 border border-slate-800 flex items-center justify-between gap-4">
                            <div class="flex items-center space-x-3">
                                <!-- Mini Visual representation -->
                                <span class="text-2xl">
                                    @if (proj.Category == "Web Projects") { <text>🌐</text> }
                                    else if (proj.Category == "Cloud Infrastructure") { <text>☁</text> }
                                    else if (proj.Category == "Hardware Builds") { <text>🖥</text> }
                                    else { <text>🚗</text> }
                                </span>
                                <div>
                                    <h3 class="text-sm font-bold text-white">@proj.Title</h3>
                                    <div class="text-[10px] text-slate-500 font-mono">ID: @proj.Id | @proj.Category</div>
                                </div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <a href="/Admin/EditProject/@proj.Id" class="px-2.5 py-1.5 rounded bg-slate-850 hover:bg-slate-800 text-xs text-slate-300 transition border border-slate-700">
                                    Edit
                                </a>
                                <form asp-controller="Admin" asp-action="DeleteProject" asp-route-id="@proj.Id" method="post" onsubmit="return confirm('Wipe project entity? This operation cannot be rolled back.')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="px-2.5 py-1.5 rounded bg-red-950/60 border border-red-500/20 text-xs text-red-400 hover:bg-red-900 hover:text-white transition">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

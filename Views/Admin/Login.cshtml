@model GaoChongPortfolio.Models.AdminLoginModel

@{
    ViewData["Title"] = "System Administration Gateway";
}

<div class="max-w-md mx-auto my-12">
    <div class="glass-panel border border-slate-800 rounded-2xl p-6 sm:p-8 shadow-2xl relative overflow-hidden">
        <!-- Floating shapes -->
        <div class="absolute -top-10 -right-10 w-24 h-24 bg-indigo-500/10 rounded-full blur-2xl"></div>

        <!-- Header -->
        <div class="mb-6 text-center select-none">
            <span class="text-4xl">🔐</span>
            <h1 class="text-2xl font-extrabold text-white mt-2">Admin Gateway</h1>
            <p class="text-xs text-slate-400 font-mono mt-1">Authenticate terminal access parameters</p>
        </div>

        <form asp-controller="Admin" asp-action="Login" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <!-- General validation alerts -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-3 rounded bg-red-950/40 border border-red-500/25 text-xs text-red-300 font-mono">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <!-- Username Input -->
            <div class="space-y-1">
                <label asp-for="Username" class="block text-[11px] font-mono text-indigo-300 uppercase tracking-wider">Username ID</label>
                <input 
                    asp-for="Username" 
                    class="w-full px-3.5 py-2.5 rounded-lg bg-slate-900 border border-slate-800 focus:border-indigo-500 text-white outline-none font-mono text-xs sm:text-sm transition focus:ring-1 focus:ring-indigo-500/50" 
                    placeholder="Enter admin ID" />
                <span asp-validation-for="Username" class="block text-[10px] text-red-400 font-mono"></span>
            </div>

            <!-- Password Input -->
            <div class="space-y-1">
                <label asp-for="Password" class="block text-[11px] font-mono text-indigo-300 uppercase tracking-wider">Access Token / Password</label>
                <input 
                    asp-for="Password" 
                    class="w-full px-3.5 py-2.5 rounded-lg bg-slate-900 border border-slate-800 focus:border-indigo-500 text-white outline-none font-mono text-xs sm:text-sm transition focus:ring-1 focus:ring-indigo-500/50" 
                    placeholder="Enter security password" />
                <span asp-validation-for="Password" class="block text-[10px] text-red-400 font-mono"></span>
            </div>

            <button 
                type="submit" 
                class="hacker-override w-full px-4 py-2.5 rounded-lg bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 text-white font-bold text-xs uppercase tracking-wider transition shadow-lg shadow-indigo-600/10 hover:shadow-indigo-600/20 transform hover:-translate-y-0.5 mt-2">
                Authorize Session
            </button>
        </form>
    </div>
</div>
